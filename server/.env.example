LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=gpt-oss:20b
LLM_TIMEOUT_SECONDS=120
LLM_API_KEY=<your_api_key>

# Meeting recording pipeline
# 1. Go to hf.co/settings/tokens and create a read token (only needed for online download)
HF_TOKEN=<your_huggingface_token>
# 2. OpenAI API key for GPT report generation
OPENAI_API_KEY=<your_openai_api_key>
# 3. Optional: fix the number of speakers for diarization (leave unset to auto-detect)
# MEETING_NUM_SPEAKERS=4
# 4. Optional: path to the directory that contains the downloaded
#    models--pyannote--speaker-diarization-3.1 HF cache folder.
#    Set this to use the model offline without an internet connection.
#    Example (folder placed inside the server/ directory):
# PYANNOTE_LOCAL_MODEL_DIR=.

# MongoDB (for caching meeting transcripts and reports)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=TeamSyncDb