# =============================================================
# TeamSync - Unified Environment Variables Reference
# =============================================================
# Copy relevant sections to frontend/.env and/or backend/.env
# =============================================================

# ----------------------------------------------------------------
# FRONTEND (frontend/.env)
# ----------------------------------------------------------------

# Backend API URL
VITE_API_URL=http://localhost:8000

# LLM (Language Model) settings — used by WeeklySummary AI report generator
VITE_LLM_BASE_URL=http://localhost:11434/v1
VITE_LLM_API_KEY=not-needed-for-local
VITE_LLM_MODEL=llama3.2

# ----------------------------------------------------------------
# BACKEND (set via environment or backend/.env — not tracked in git)
# ----------------------------------------------------------------

# JWT
JWT_SECRET_KEY=super-secret-key-for-teamsync-development-only-32chars

# MongoDB
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DATABASE_NAME=TeamSyncDb

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# VLM Image Generation (used by VlmImageService for project banner images)
VLM_BASE_URL=http://your-vlm-host/
VLM_API_KEY=your-vlm-api-key
VLM_MODEL=your-model-name
VLM_IMAGE_SIZE=1024x1024
VLM_TIMEOUT_SECONDS=8
